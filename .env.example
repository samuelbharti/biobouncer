# Copy this file to .env and fill in local values. The real .env is gitignored.
# biobouncer needs no secrets for pattern or cache modes. These only matter for
# optional remote-mode API access during development.

# Contact email that some biological APIs ask for in the request User-Agent.
BIOBOUNCER_CONTACT_EMAIL=

# NCBI API key to raise dbSNP and RefSeq rate limits.
NCBI_API_KEY=
